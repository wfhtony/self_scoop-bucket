{
    "version": "0.6.0-beta+20260628161301",
    "description": "DASH/HLS/MSS stream downloader supporting on-demand & live broadcasts",
    "homepage": "https://github.com/nilaoda/N_m3u8DL-RE",
    "license": "MIT",
    "suggest": {
        "ffmpeg": [
            "ffmpeg-nightly",
            "ffmpeg"
        ],
        "shaka-packager/mp4decrypt": [
            "self_scoop-bucket/shaka-packager",
            "bento4"
        ],
        "mkvmerge": "mkvtoolnix"
    },
    "architecture": {
        "64bit": {
            "url": "https://github.com/nilaoda/N_m3u8DL-RE/releases/download/v0.6.0-beta/N_m3u8DL-RE_v0.6.0-beta_win-x64_20260629.zip",
            "hash": "3825fd42ee502f98a9378f6fdddb2f7822709f521806214f466db6935c950f1a"
        }
    },
    "bin": "N_m3u8DL-RE.exe",
    "checkver": {
        "script": [
            "$cont = (Invoke-RestMethod -UseBasicParsing -Uri 'https://api.github.com/repos/nilaoda/N_m3u8DL-RE/releases?per_page=1')[0]",
            "$basever = $cont.tag_name.TrimStart('v')",
            "foreach ($_ in $cont.assets) {",
            "  if ($_.name -match '^N_m3u8DL-RE_v[\\w.-]+_win-x64_(\\d+)\\.zip$') {",
            "    $date = $matches[1]",
            "    $updated_date = ([DateTime]$_.updated_at).ToUniversalTime().ToString('yyyyMMddHHmmss')",
            "    Write-Output ('basever:\"' + $basever + '\"') ('date:\"' + $date + '\"') ('updated_date:\"' + $updated_date + '\"')",
            "    break",
            "  }",
            "}"
        ],
        "regex": "basever:\"(?<basever>[\\w.-]+)\"\\sdate:\"(?<date>\\d+)\"\\supdated_date:\"(?<updated_date>\\d+)\"",
        "replace": "${basever}+${updated_date}"
    },
    "autoupdate": {
        "architecture": {
            "64bit": {
                "url": "https://github.com/nilaoda/N_m3u8DL-RE/releases/download/v$matchBasever/N_m3u8DL-RE_v$matchBasever_win-x64_$matchDate.zip"
            }
        }
    }
}
